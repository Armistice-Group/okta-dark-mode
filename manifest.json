{
  "manifest_version": 3,
  "name": "Okta Dark Mode",
  "version": "1.0.0",
  "description": "Dark mode theme for Okta dashboard with glassmorphism effects and hover glow",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.okta.com/*",
    "https://*.okta-emea.com/*",
    "https://*.oktapreview.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.okta.com/*",
        "https://*.okta-emea.com/*",
        "https://*.oktapreview.com/*"
      ],
      "js": ["content-init.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*.okta.com/*",
        "https://*.okta-emea.com/*",
        "https://*.oktapreview.com/*"
      ],
      "js": ["icon-overrides.js", "content-icons.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css", "icon-overrides/*"],
      "matches": [
        "https://*.okta.com/*",
        "https://*.okta-emea.com/*",
        "https://*.oktapreview.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
